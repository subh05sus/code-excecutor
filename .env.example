INTERNAL_TOKEN=change-me-strong-secret
PORT=3000
NODE_ENV=development

# Bulk transcript generation (callbacks into SparkMentis reuse INTERNAL_TOKEN)
TRANSCRIPT_WORKER_CONCURRENCY=3

# S3 (also used for transcript PDFs; transcript worker writes to the bucket
# SparkMentis requests, so its IAM user must have PutObject on that bucket)
PDF_S3_BUCKET=sparkmentis-uploads
PDF_S3_REGION=us-east-1
